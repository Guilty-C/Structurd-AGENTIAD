{
  "recipe_name": "prompt_1_5_ms_swift_fixture_v1",
  "framework_owner": "ms-swift",
  "dataset": {
    "output_jsonl": "prompt_1_5_ms_swift_dataset.jsonl",
    "manifest_json": "prompt_1_5_ms_swift_dataset.manifest.json",
    "dataset_name": "agentiad_prompt_1_5_fixture",
    "tools": [
      {
        "name": "PZ",
        "description": "Deterministic crop or zoom over the primary image."
      },
      {
        "name": "CR",
        "description": "Deterministic same-category normal exemplar retrieval."
      }
    ]
  },
  "training": {
