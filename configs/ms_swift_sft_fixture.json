    "num_train_epochs": 1,
    "per_device_train_batch_size": 1,
    "gradient_accumulation_steps": 1,
    "learning_rate": 0.0001,
    "max_length": 4096,
    "checkpoint_dir": "dist/outputs/prompt_1_5_ms_swift_checkpoints"
  },
  "logging": {
    "logging_dir": "dist/outputs/prompt_1_5_ms_swift_logs",
    "logging_steps": 1,
    "report_to": ["tensorboard"]
  },
  "resume": {
    "resume_from_checkpoint": null,
    "load_args_from_ckpt_dir": false
  }
}
