{
  "recipe_name": "prompt_1_5_ms_swift_remote_template_v1",
  "framework_owner": "ms-swift",
  "dataset": {
    "output_jsonl": "agentiad_prompt_1_5_remote_ms_swift_dataset.jsonl",
    "manifest_json": "agentiad_prompt_1_5_remote_ms_swift_dataset.manifest.json",
    "dataset_name": "agentiad_prompt_1_5_remote",
    "tools": [
      {
        "name": "PZ",
