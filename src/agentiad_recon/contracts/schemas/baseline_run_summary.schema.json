{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentiad.local/baseline_run_summary.schema.json",
  "title": "AgentIADBaselineRunSummary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "tool_mode",
    "backend_name",
    "prompt_version",
    "parser_version",
    "execution_boundary",
    "sample_source",
    "seeds",
    "sample_count",
    "evaluated_count",
    "failed_count",
    "parser_validity",
    "schema_validity",
    "runtime_provenance",
    "artifact_paths"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "tool_mode": {
      "type": "string",
      "enum": ["no_tools", "pz_only", "pz_cr"]
    },
    "backend_name": { "type": "string", "minLength": 1 },
    "prompt_version": { "type": "string", "minLength": 1 },
    "parser_version": { "type": "string", "minLength": 1 },
    "execution_boundary": {
      "type": "string",
      "enum": ["local", "remote"]
    },
    "sample_source": {
      "type": "object",
      "additionalProperties": true
    },
    "seeds": {
      "type": "array",
      "items": { "type": "integer" },
      "minItems": 1
    },
    "sample_count": { "type": "integer", "minimum": 0 },
    "evaluated_count": { "type": "integer", "minimum": 0 },
    "failed_count": { "type": "integer", "minimum": 0 },
    "tool_first_intervention_strategy": {
      "type": "string",
      "enum": ["baseline", "tool_first_nudge", "tool_first_strict"]
    },
    "first_turn_protocol_gate_mode": {
      "type": "string",
      "enum": ["off", "retry_once_pz_cr"]
    },
    "parser_validity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["valid", "invalid"],
      "properties": {
        "valid": { "type": "integer", "minimum": 0 },
        "invalid": { "type": "integer", "minimum": 0 }
      }
    },
    "schema_validity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["valid", "invalid"],
      "properties": {
        "valid": { "type": "integer", "minimum": 0 },
        "invalid": { "type": "integer", "minimum": 0 }
      }
    },
    "tool_usage_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total_calls", "samples_with_tool_calls", "per_tool_counts"],
      "properties": {
        "total_calls": { "type": "integer", "minimum": 0 },
        "samples_with_tool_calls": { "type": "integer", "minimum": 0 },
        "per_tool_counts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["PZ", "CR"],
          "properties": {
            "PZ": { "type": "integer", "minimum": 0 },
            "CR": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "normalization_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_count",
        "samples_with_events",
        "mixed_tool_call_and_final_answer_count",
        "multiple_tool_calls_in_single_output_count",
        "discarded_premature_final_answer_count",
        "additional_valid_tool_calls_discarded_count"
      ],
      "properties": {
        "event_count": { "type": "integer", "minimum": 0 },
        "samples_with_events": { "type": "integer", "minimum": 0 },
        "mixed_tool_call_and_final_answer_count": { "type": "integer", "minimum": 0 },
        "multiple_tool_calls_in_single_output_count": { "type": "integer", "minimum": 0 },
        "discarded_premature_final_answer_count": { "type": "integer", "minimum": 0 },
        "additional_valid_tool_calls_discarded_count": { "type": "integer", "minimum": 0 }
      }
    },
    "prompt_audit_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prompt_audit_event_count",
        "samples_with_prompt_audit_mismatch",
        "mode_contract_missing_cr_tool_count",
        "mode_contract_pz_only_leakage_count",
        "failed_count_with_missing_reason_count"
      ],
      "properties": {
        "prompt_audit_event_count": { "type": "integer", "minimum": 0 },
        "samples_with_prompt_audit_mismatch": { "type": "integer", "minimum": 0 },
        "mode_contract_missing_cr_tool_count": { "type": "integer", "minimum": 0 },
        "mode_contract_pz_only_leakage_count": { "type": "integer", "minimum": 0 },
        "failed_count_with_missing_reason_count": { "type": "integer", "minimum": 0 }
      }
    },
    "zero_tool_behavior_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "turn0_direct_final_answer_count",
        "turn0_tool_call_count",
        "samples_with_any_tool_call",
        "zero_tool_terminal_count",
        "zero_tool_terminal_false_null_count",
        "zero_tool_terminal_ratio",
        "zero_tool_terminal_false_null_ratio",
        "failed_count_with_missing_reason_count"
      ],
      "properties": {
        "turn0_direct_final_answer_count": { "type": "integer", "minimum": 0 },
        "turn0_tool_call_count": { "type": "integer", "minimum": 0 },
        "samples_with_any_tool_call": { "type": "integer", "minimum": 0 },
        "zero_tool_terminal_count": { "type": "integer", "minimum": 0 },
        "zero_tool_terminal_false_null_count": { "type": "integer", "minimum": 0 },
        "zero_tool_terminal_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
        "zero_tool_terminal_false_null_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
        "failed_count_with_missing_reason_count": { "type": "integer", "minimum": 0 }
      }
    },
    "first_turn_gate_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "first_turn_gate_trigger_count",
        "samples_with_first_turn_gate_events",
        "first_turn_gate_recovered_to_tool_call_count",
        "first_turn_gate_still_terminal_count",
        "first_turn_gate_retry_parse_failure_count",
        "first_turn_gate_recovery_rate"
      ],
      "properties": {
        "first_turn_gate_trigger_count": { "type": "integer", "minimum": 0 },
        "samples_with_first_turn_gate_events": { "type": "integer", "minimum": 0 },
        "first_turn_gate_recovered_to_tool_call_count": { "type": "integer", "minimum": 0 },
        "first_turn_gate_still_terminal_count": { "type": "integer", "minimum": 0 },
        "first_turn_gate_retry_parse_failure_count": { "type": "integer", "minimum": 0 },
        "first_turn_gate_recovery_rate": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "first_turn_gate_repair_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "first_turn_gate_repair_attempt_count",
        "first_turn_gate_repair_success_count",
        "first_turn_gate_repair_failure_count",
        "first_turn_gate_repair_wrapper_recovery_count",
        "first_turn_gate_repair_quote_normalization_count",
        "first_turn_gate_repair_duplicate_candidate_deduplication_count",
        "first_turn_gate_repair_alias_canonicalization_count",
        "first_turn_gate_repair_bbox_canonicalization_count",
        "first_turn_gate_repair_failure_families",
        "failed_count_with_missing_reason_count"
      ],
      "properties": {
        "first_turn_gate_repair_attempt_count": { "type": "integer", "minimum": 0 },
        "first_turn_gate_repair_success_count": { "type": "integer", "minimum": 0 },
        "first_turn_gate_repair_failure_count": { "type": "integer", "minimum": 0 },
        "first_turn_gate_repair_wrapper_recovery_count": { "type": "integer", "minimum": 0 },
        "first_turn_gate_repair_quote_normalization_count": { "type": "integer", "minimum": 0 },
        "first_turn_gate_repair_duplicate_candidate_deduplication_count": { "type": "integer", "minimum": 0 },
        "first_turn_gate_repair_alias_canonicalization_count": { "type": "integer", "minimum": 0 },
        "first_turn_gate_repair_bbox_canonicalization_count": { "type": "integer", "minimum": 0 },
        "first_turn_gate_repair_failure_families": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "retry_repair_unrecoverable_pseudo_observation_payload",
            "retry_repair_ambiguous_multiple_candidates",
            "retry_repair_bbox_not_losslessly_recoverable",
            "retry_repair_unsupported_payload_shape",
            "retry_repair_no_unique_candidate"
          ],
          "properties": {
            "retry_repair_unrecoverable_pseudo_observation_payload": { "type": "integer", "minimum": 0 },
            "retry_repair_ambiguous_multiple_candidates": { "type": "integer", "minimum": 0 },
            "retry_repair_bbox_not_losslessly_recoverable": { "type": "integer", "minimum": 0 },
            "retry_repair_unsupported_payload_shape": { "type": "integer", "minimum": 0 },
            "retry_repair_no_unique_candidate": { "type": "integer", "minimum": 0 }
          }
        },
        "failed_count_with_missing_reason_count": { "type": "integer", "minimum": 0 }
      }
    },
    "runtime_provenance": {
      "$ref": "#/$defs/runtimeProvenance"
    },
    "artifact_paths": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "predictions_dir",
        "traces_dir",
        "raw_outputs_dir",
        "metrics_report",
        "per_seed_metrics",
        "per_class_metrics",
        "aggregate_metrics",
        "run_metadata",
        "run_manifest"
      ],
      "properties": {
        "predictions_dir": { "type": "string", "minLength": 1 },
        "traces_dir": { "type": "string", "minLength": 1 },
        "raw_outputs_dir": { "type": "string", "minLength": 1 },
        "metrics_report": { "type": "string", "minLength": 1 },
        "per_seed_metrics": { "type": "string", "minLength": 1 },
        "per_class_metrics": { "type": "string", "minLength": 1 },
        "aggregate_metrics": { "type": "string", "minLength": 1 },
        "run_metadata": { "type": "string", "minLength": 1 },
        "run_manifest": { "type": "string", "minLength": 1 },
        "delta_report": { "type": "string" },
        "per_dataset_zero_tool_behavior": { "type": "string", "minLength": 1 },
        "per_category_zero_tool_behavior": { "type": "string", "minLength": 1 },
        "first_turn_gate_repair_failure_families": { "type": "string", "minLength": 1 },
        "tool_first_strategy_summary": { "type": "string", "minLength": 1 }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "generationConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_new_tokens", "do_sample", "temperature", "top_p"],
      "properties": {
        "max_new_tokens": { "type": "integer", "minimum": 1 },
        "do_sample": { "type": "boolean" },
        "temperature": { "type": "number", "minimum": 0 },
        "top_p": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "runtimeProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_backend_name",
        "runtime_backend_type",
        "runtime_owner",
        "policy",
        "base_model_path",
        "adapter_checkpoint_path",
        "adapter_loaded",
        "checkpoint_step",
        "checkpoint_run_dir",
        "dataset_root",
        "tool_mode",
        "inference_mode",
        "generation_config",
        "local_files_only",
        "trust_remote_code",
        "dtype",
        "device",
        "tool_first_intervention_strategy",
        "first_turn_protocol_gate_mode"
      ],
      "properties": {
        "runtime_backend_name": { "type": "string", "minLength": 1 },
        "runtime_backend_type": { "type": "string", "minLength": 1 },
        "runtime_owner": { "type": "string", "minLength": 1 },
        "policy": { "type": "string", "minLength": 1 },
        "base_model_path": { "type": ["string", "null"] },
        "adapter_checkpoint_path": { "type": ["string", "null"] },
        "adapter_loaded": { "type": "boolean" },
        "checkpoint_step": { "type": ["integer", "null"], "minimum": 0 },
        "checkpoint_run_dir": { "type": ["string", "null"] },
        "dataset_root": { "type": "string", "minLength": 1 },
        "tool_mode": {
          "type": "string",
          "enum": ["no_tools", "pz_only", "pz_cr"]
        },
        "inference_mode": {
          "type": "string",
          "enum": ["no_tools", "pz_only", "pz_cr"]
        },
        "generation_config": {
          "$ref": "#/$defs/generationConfig"
        },
        "local_files_only": { "type": "boolean" },
        "trust_remote_code": { "type": "boolean" },
        "dtype": { "type": "string", "minLength": 1 },
        "device": { "type": "string", "minLength": 1 },
        "tool_first_intervention_strategy": {
          "type": "string",
          "enum": ["baseline", "tool_first_nudge", "tool_first_strict"]
        },
        "first_turn_protocol_gate_mode": {
          "type": "string",
          "enum": ["off", "retry_once_pz_cr"]
        }
      }
    }
  }
}
