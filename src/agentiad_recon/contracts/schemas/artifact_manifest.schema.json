{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentiad.local/artifact_manifest.schema.json",
  "title": "AgentIADArtifactManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_type",
    "created_at",
    "producer",
    "content_hash",
    "input_hashes",
    "execution_boundary"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "type": "string",
      "enum": [
        "config",
        "dataset_manifest",
        "trajectory",
        "reward_bundle",
        "report",
        "checkpoint_reference"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "producer": {
      "type": "string",
      "minLength": 1
    },
    "content_hash": {
      "type": "string",
      "minLength": 1
    },
    "input_hashes": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "execution_boundary": {
      "type": "string",
      "enum": ["local", "remote"]
    },
    "tool_first_intervention_strategy": {
      "type": "string",
      "enum": ["baseline", "tool_first_nudge", "tool_first_strict"]
    },
    "first_turn_protocol_gate_mode": {
      "type": "string",
      "enum": ["off", "retry_once_pz_cr"]
    },
    "post_pz_second_turn_gate_mode": {
      "type": "string",
      "enum": ["off", "retry_once_require_cr_after_pz"]
    },
    "artifact_level": {
      "type": "string",
      "enum": ["forensic", "throughput"]
    },
    "emit_baseline_compare": { "type": "boolean" },
    "emit_delta_report": { "type": "boolean" },
    "timing_enabled": { "type": "boolean" },
    "progress_mode": {
      "type": "string",
      "enum": ["off", "auto", "bar", "log"]
    },
    "shard_summary": {
      "$ref": "#/$defs/shardSummary"
    },
    "run_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_backend_name",
        "runtime_backend_type",
        "runtime_owner",
        "policy",
        "base_model_path",
        "adapter_checkpoint_path",
        "adapter_loaded",
        "checkpoint_step",
        "checkpoint_run_dir",
        "dataset_root",
        "tool_mode",
        "inference_mode",
        "generation_config",
        "local_files_only",
        "trust_remote_code",
        "dtype",
        "device",
        "tool_first_intervention_strategy",
        "first_turn_protocol_gate_mode",
        "post_pz_second_turn_gate_mode",
        "generation_stage_overrides",
        "emit_baseline_compare",
        "emit_delta_report",
        "artifact_level",
        "timing_enabled",
        "progress_mode",
        "progress_update_every_n_samples",
        "progress_snapshot_path",
        "num_shards",
        "shard_index",
        "full_sample_count",
        "selected_sample_count",
        "sharding_strategy"
      ],
      "properties": {
        "runtime_backend_name": { "type": "string", "minLength": 1 },
        "runtime_backend_type": { "type": "string", "minLength": 1 },
        "runtime_owner": { "type": "string", "minLength": 1 },
        "policy": { "type": "string", "minLength": 1 },
        "base_model_path": { "type": ["string", "null"] },
        "adapter_checkpoint_path": { "type": ["string", "null"] },
        "adapter_loaded": { "type": "boolean" },
        "checkpoint_step": { "type": ["integer", "null"], "minimum": 0 },
        "checkpoint_run_dir": { "type": ["string", "null"] },
        "dataset_root": { "type": "string", "minLength": 1 },
        "tool_mode": {
          "type": "string",
          "enum": ["no_tools", "pz_only", "pz_cr"]
        },
        "inference_mode": {
          "type": "string",
          "enum": ["no_tools", "pz_only", "pz_cr"]
        },
        "generation_config": {
          "type": "object",
          "additionalProperties": false,
          "required": ["max_new_tokens", "do_sample", "temperature", "top_p"],
          "properties": {
            "max_new_tokens": { "type": "integer", "minimum": 1 },
            "do_sample": { "type": "boolean" },
            "temperature": { "type": "number", "minimum": 0 },
            "top_p": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "generation_stage_overrides": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "turn0_initial": { "$ref": "#/$defs/generationOverride" },
            "turn0_retry": { "$ref": "#/$defs/generationOverride" },
            "post_pz_second_turn": { "$ref": "#/$defs/generationOverride" },
            "post_pz_second_turn_retry": { "$ref": "#/$defs/generationOverride" },
            "final_answer": { "$ref": "#/$defs/generationOverride" }
          }
        },
        "local_files_only": { "type": "boolean" },
        "trust_remote_code": { "type": "boolean" },
        "dtype": { "type": "string", "minLength": 1 },
        "device": { "type": "string", "minLength": 1 },
        "tool_first_intervention_strategy": {
          "type": "string",
          "enum": ["baseline", "tool_first_nudge", "tool_first_strict"]
        },
        "first_turn_protocol_gate_mode": {
          "type": "string",
          "enum": ["off", "retry_once_pz_cr"]
        },
        "post_pz_second_turn_gate_mode": {
          "type": "string",
          "enum": ["off", "retry_once_require_cr_after_pz"]
        },
        "emit_baseline_compare": { "type": "boolean" },
        "emit_delta_report": { "type": "boolean" },
        "artifact_level": {
          "type": "string",
          "enum": ["forensic", "throughput"]
        },
        "timing_enabled": { "type": "boolean" },
        "progress_mode": {
          "type": "string",
          "enum": ["off", "auto", "bar", "log"]
        },
        "progress_update_every_n_samples": {
          "type": "integer",
          "minimum": 1
        },
        "progress_snapshot_path": {
          "type": ["string", "null"]
        },
        "num_shards": {
          "type": "integer",
          "minimum": 1
        },
        "shard_index": {
          "type": "integer",
          "minimum": 0
        },
        "full_sample_count": {
          "type": "integer",
          "minimum": 0
        },
        "selected_sample_count": {
          "type": "integer",
          "minimum": 0
        },
        "sharding_strategy": {
          "type": "string",
          "const": "stable_index_mod"
        }
      }
    },
    "normalization_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_count",
        "samples_with_events",
        "mixed_tool_call_and_final_answer_count",
        "multiple_tool_calls_in_single_output_count",
        "discarded_premature_final_answer_count",
        "additional_valid_tool_calls_discarded_count"
      ],
      "properties": {
        "event_count": { "type": "integer", "minimum": 0 },
        "samples_with_events": { "type": "integer", "minimum": 0 },
        "mixed_tool_call_and_final_answer_count": { "type": "integer", "minimum": 0 },
        "multiple_tool_calls_in_single_output_count": { "type": "integer", "minimum": 0 },
        "discarded_premature_final_answer_count": { "type": "integer", "minimum": 0 },
        "additional_valid_tool_calls_discarded_count": { "type": "integer", "minimum": 0 }
      }
    },
    "prompt_audit_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prompt_audit_event_count",
        "samples_with_prompt_audit_mismatch",
        "mode_contract_missing_cr_tool_count",
        "mode_contract_pz_only_leakage_count",
        "failed_count_with_missing_reason_count"
      ],
      "properties": {
        "prompt_audit_event_count": { "type": "integer", "minimum": 0 },
        "samples_with_prompt_audit_mismatch": { "type": "integer", "minimum": 0 },
        "mode_contract_missing_cr_tool_count": { "type": "integer", "minimum": 0 },
        "mode_contract_pz_only_leakage_count": { "type": "integer", "minimum": 0 },
        "failed_count_with_missing_reason_count": { "type": "integer", "minimum": 0 }
      }
    },
    "zero_tool_behavior_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "turn0_direct_final_answer_count",
        "turn0_tool_call_count",
        "samples_with_any_tool_call",
        "zero_tool_terminal_count",
        "zero_tool_terminal_false_null_count",
        "zero_tool_terminal_ratio",
        "zero_tool_terminal_false_null_ratio",
        "failed_count_with_missing_reason_count"
      ],
      "properties": {
        "turn0_direct_final_answer_count": { "type": "integer", "minimum": 0 },
        "turn0_tool_call_count": { "type": "integer", "minimum": 0 },
        "samples_with_any_tool_call": { "type": "integer", "minimum": 0 },
        "zero_tool_terminal_count": { "type": "integer", "minimum": 0 },
        "zero_tool_terminal_false_null_count": { "type": "integer", "minimum": 0 },
        "zero_tool_terminal_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
        "zero_tool_terminal_false_null_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
        "failed_count_with_missing_reason_count": { "type": "integer", "minimum": 0 }
      }
    },
    "post_pz_transition_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "post_pz_transition_event_count",
        "samples_with_post_pz_transition_events",
        "post_pz_transition_contract_valid_count",
        "post_pz_transition_contract_mismatch_count",
        "post_pz_transition_missing_reinserted_pz_result_count",
        "post_pz_transition_missing_cr_tool_count",
        "post_pz_transition_missing_query_image_instruction_count",
        "post_pz_transition_pz_only_leakage_count",
        "post_pz_transition_missing_tool_context_count",
        "post_pz_second_turn_direct_final_without_cr_count",
        "post_pz_second_turn_called_cr_count",
        "post_pz_second_turn_called_non_cr_tool_count",
        "post_pz_second_turn_parser_failure_count",
        "failed_count_with_missing_reason_count"
      ],
      "properties": {
        "post_pz_transition_event_count": { "type": "integer", "minimum": 0 },
        "samples_with_post_pz_transition_events": { "type": "integer", "minimum": 0 },
        "post_pz_transition_contract_valid_count": { "type": "integer", "minimum": 0 },
        "post_pz_transition_contract_mismatch_count": { "type": "integer", "minimum": 0 },
        "post_pz_transition_missing_reinserted_pz_result_count": { "type": "integer", "minimum": 0 },
        "post_pz_transition_missing_cr_tool_count": { "type": "integer", "minimum": 0 },
        "post_pz_transition_missing_query_image_instruction_count": { "type": "integer", "minimum": 0 },
        "post_pz_transition_pz_only_leakage_count": { "type": "integer", "minimum": 0 },
        "post_pz_transition_missing_tool_context_count": { "type": "integer", "minimum": 0 },
        "post_pz_second_turn_direct_final_without_cr_count": { "type": "integer", "minimum": 0 },
        "post_pz_second_turn_called_cr_count": { "type": "integer", "minimum": 0 },
        "post_pz_second_turn_called_non_cr_tool_count": { "type": "integer", "minimum": 0 },
        "post_pz_second_turn_parser_failure_count": { "type": "integer", "minimum": 0 },
        "failed_count_with_missing_reason_count": { "type": "integer", "minimum": 0 }
      }
    },
    "post_pz_transition_sanitation_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "post_pz_transition_sanitation_event_count",
        "samples_with_post_pz_transition_sanitation_events",
        "post_pz_transition_sanitation_applied_count",
        "post_pz_transition_removed_message_total",
        "post_pz_transition_removed_obsolete_terminal_answer_total",
        "post_pz_transition_removed_pz_only_leakage_message_total",
        "post_pz_transition_pre_sanitation_pz_only_leakage_count",
        "post_pz_transition_post_sanitation_pz_only_leakage_count",
        "post_pz_transition_post_sanitation_contract_valid_count",
        "post_pz_transition_post_sanitation_contract_mismatch_count",
        "post_pz_second_turn_direct_final_without_cr_count",
        "post_pz_second_turn_called_cr_count",
        "failed_count_with_missing_reason_count"
      ],
      "properties": {
        "post_pz_transition_sanitation_event_count": { "type": "integer", "minimum": 0 },
        "samples_with_post_pz_transition_sanitation_events": { "type": "integer", "minimum": 0 },
        "post_pz_transition_sanitation_applied_count": { "type": "integer", "minimum": 0 },
        "post_pz_transition_removed_message_total": { "type": "integer", "minimum": 0 },
        "post_pz_transition_removed_obsolete_terminal_answer_total": { "type": "integer", "minimum": 0 },
        "post_pz_transition_removed_pz_only_leakage_message_total": { "type": "integer", "minimum": 0 },
        "post_pz_transition_pre_sanitation_pz_only_leakage_count": { "type": "integer", "minimum": 0 },
        "post_pz_transition_post_sanitation_pz_only_leakage_count": { "type": "integer", "minimum": 0 },
        "post_pz_transition_post_sanitation_contract_valid_count": { "type": "integer", "minimum": 0 },
        "post_pz_transition_post_sanitation_contract_mismatch_count": { "type": "integer", "minimum": 0 },
        "post_pz_second_turn_direct_final_without_cr_count": { "type": "integer", "minimum": 0 },
        "post_pz_second_turn_called_cr_count": { "type": "integer", "minimum": 0 },
        "failed_count_with_missing_reason_count": { "type": "integer", "minimum": 0 }
      }
    },
    "post_pz_second_turn_gate_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "post_pz_second_turn_gate_trigger_count",
        "samples_with_post_pz_second_turn_gate_events",
        "post_pz_second_turn_gate_recovered_to_cr_call_count",
        "post_pz_second_turn_gate_retry_parse_failure_count",
        "post_pz_second_turn_gate_still_terminal_count",
        "post_pz_second_turn_gate_called_non_cr_tool_count",
        "post_pz_second_turn_gate_called_cr_but_later_failed_execution_or_contract_count",
        "post_pz_second_turn_gate_not_triggered_count",
        "post_pz_second_turn_gate_recovery_rate",
        "failed_count_with_missing_reason_count"
      ],
      "properties": {
        "post_pz_second_turn_gate_trigger_count": { "type": "integer", "minimum": 0 },
        "samples_with_post_pz_second_turn_gate_events": { "type": "integer", "minimum": 0 },
        "post_pz_second_turn_gate_recovered_to_cr_call_count": { "type": "integer", "minimum": 0 },
        "post_pz_second_turn_gate_retry_parse_failure_count": { "type": "integer", "minimum": 0 },
        "post_pz_second_turn_gate_still_terminal_count": { "type": "integer", "minimum": 0 },
        "post_pz_second_turn_gate_called_non_cr_tool_count": { "type": "integer", "minimum": 0 },
        "post_pz_second_turn_gate_called_cr_but_later_failed_execution_or_contract_count": {
          "type": "integer",
          "minimum": 0
        },
        "post_pz_second_turn_gate_not_triggered_count": { "type": "integer", "minimum": 0 },
        "post_pz_second_turn_gate_recovery_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "failed_count_with_missing_reason_count": { "type": "integer", "minimum": 0 }
      }
    },
    "timing_summary": {
      "$ref": "#/$defs/timingSummary"
    },
    "core_artifacts_written_before_optional_tail_work": {
      "type": "boolean"
    },
    "first_turn_gate_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "first_turn_gate_trigger_count",
        "samples_with_first_turn_gate_events",
        "first_turn_gate_recovered_to_tool_call_count",
        "first_turn_gate_still_terminal_count",
        "first_turn_gate_retry_parse_failure_count",
        "first_turn_gate_recovery_rate"
      ],
      "properties": {
        "first_turn_gate_trigger_count": { "type": "integer", "minimum": 0 },
        "samples_with_first_turn_gate_events": { "type": "integer", "minimum": 0 },
        "first_turn_gate_recovered_to_tool_call_count": { "type": "integer", "minimum": 0 },
        "first_turn_gate_still_terminal_count": { "type": "integer", "minimum": 0 },
        "first_turn_gate_retry_parse_failure_count": { "type": "integer", "minimum": 0 },
        "first_turn_gate_recovery_rate": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "first_turn_gate_repair_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "first_turn_gate_repair_attempt_count",
        "first_turn_gate_repair_success_count",
        "first_turn_gate_repair_failure_count",
        "first_turn_gate_repair_wrapper_recovery_count",
        "first_turn_gate_repair_quote_normalization_count",
        "first_turn_gate_repair_duplicate_candidate_deduplication_count",
        "first_turn_gate_repair_alias_canonicalization_count",
        "first_turn_gate_repair_bbox_canonicalization_count",
        "first_turn_gate_repair_failure_families",
        "failed_count_with_missing_reason_count"
      ],
      "properties": {
        "first_turn_gate_repair_attempt_count": { "type": "integer", "minimum": 0 },
        "first_turn_gate_repair_success_count": { "type": "integer", "minimum": 0 },
        "first_turn_gate_repair_failure_count": { "type": "integer", "minimum": 0 },
        "first_turn_gate_repair_wrapper_recovery_count": { "type": "integer", "minimum": 0 },
        "first_turn_gate_repair_quote_normalization_count": { "type": "integer", "minimum": 0 },
        "first_turn_gate_repair_duplicate_candidate_deduplication_count": { "type": "integer", "minimum": 0 },
        "first_turn_gate_repair_alias_canonicalization_count": { "type": "integer", "minimum": 0 },
        "first_turn_gate_repair_bbox_canonicalization_count": { "type": "integer", "minimum": 0 },
        "first_turn_gate_repair_failure_families": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "retry_repair_unrecoverable_pseudo_observation_payload",
            "retry_repair_ambiguous_multiple_candidates",
            "retry_repair_bbox_not_losslessly_recoverable",
            "retry_repair_unsupported_payload_shape",
            "retry_repair_no_unique_candidate"
          ],
          "properties": {
            "retry_repair_unrecoverable_pseudo_observation_payload": { "type": "integer", "minimum": 0 },
            "retry_repair_ambiguous_multiple_candidates": { "type": "integer", "minimum": 0 },
            "retry_repair_bbox_not_losslessly_recoverable": { "type": "integer", "minimum": 0 },
            "retry_repair_unsupported_payload_shape": { "type": "integer", "minimum": 0 },
            "retry_repair_no_unique_candidate": { "type": "integer", "minimum": 0 }
          }
        },
        "failed_count_with_missing_reason_count": { "type": "integer", "minimum": 0 }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "shardSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "num_shards",
        "shard_index",
        "full_sample_count",
        "selected_sample_count",
        "sharding_strategy"
      ],
      "properties": {
        "num_shards": { "type": "integer", "minimum": 1 },
        "shard_index": { "type": "integer", "minimum": 0 },
        "full_sample_count": { "type": "integer", "minimum": 0 },
        "selected_sample_count": { "type": "integer", "minimum": 0 },
        "sharding_strategy": {
          "type": "string",
          "const": "stable_index_mod"
        }
      }
    },
    "generationOverride": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_new_tokens": { "type": "integer", "minimum": 1 },
        "do_sample": { "type": "boolean" },
        "temperature": { "type": "number", "minimum": 0 },
        "top_p": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "timingSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prompt_render_ms_total",
        "request_build_or_processor_ms_total",
        "generate_ms_total",
        "tool_exec_ms_total",
        "parse_validate_ms_total",
        "file_write_ms_total",
        "tail_compare_delta_ms_total",
        "generation_call_count_total",
        "retry_count_total",
        "avg_generate_ms_per_sample"
      ],
      "properties": {
        "prompt_render_ms_total": { "type": "number", "minimum": 0 },
        "request_build_or_processor_ms_total": { "type": "number", "minimum": 0 },
        "generate_ms_total": { "type": "number", "minimum": 0 },
        "tool_exec_ms_total": { "type": "number", "minimum": 0 },
        "parse_validate_ms_total": { "type": "number", "minimum": 0 },
        "file_write_ms_total": { "type": "number", "minimum": 0 },
        "tail_compare_delta_ms_total": { "type": "number", "minimum": 0 },
        "generation_call_count_total": { "type": "integer", "minimum": 0 },
        "retry_count_total": { "type": "integer", "minimum": 0 },
        "avg_generate_ms_per_sample": { "type": "number", "minimum": 0 }
      }
    }
  }
}
