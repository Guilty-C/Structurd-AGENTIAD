{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentiad.local/artifact_manifest.schema.json",
  "title": "AgentIADArtifactManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_type",
    "created_at",
    "producer",
    "content_hash",
    "input_hashes",
    "execution_boundary"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "type": "string",
      "enum": [
        "config",
        "dataset_manifest",
        "trajectory",
        "reward_bundle",
        "report",
        "checkpoint_reference"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "producer": {
      "type": "string",
      "minLength": 1
    },
    "content_hash": {
      "type": "string",
      "minLength": 1
    },
    "input_hashes": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "execution_boundary": {
      "type": "string",
      "enum": ["local", "remote"]
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
