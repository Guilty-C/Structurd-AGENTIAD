{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentiad.local/tool_call.schema.json",
  "title": "AgentIADToolCall",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "call_id",
    "tool_name",
    "status",
    "arguments",
    "output_ref",
    "output_payload"
  ],
  "properties": {
    "call_id": {
      "type": "string",
      "minLength": 1
    },
    "tool_name": {
      "type": "string",
      "enum": ["PZ", "CR"]
    },
    "status": {
      "type": "string",
      "enum": ["requested", "completed", "failed"]
    },
    "arguments": {
      "type": "object",
      "additionalProperties": true
    },
    "output_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id"],
      "properties": {
        "artifact_id": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string" }
      }
    },
    "output_payload": {
      "type": "object",
      "additionalProperties": true
    },
    "raw_text": {
      "type": "string"
    },
    "audit_log": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
