{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentiad/tool_call.schema.json",
  "title": "AgentIADToolCall",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "call_id",
    "tool_name",
    "status",
    "arguments",
    "output_ref"
  ],
  "properties": {
    "call_id": {
      "type": "string",
      "minLength": 1
    },
    "tool_name": {
      "type": "string",
      "enum": ["PZ", "CR"]
    },
    "status": {
      "type": "string",
      "enum": ["requested", "completed", "failed"]
    },
    "arguments": {
      "type": "object"
    },
    "output_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id"],
      "properties": {
        "artifact_id": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string" }
      }
    }
  }
}
