{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentiad.local/sft_dataset_manifest.schema.json",
  "title": "AgentIADSFTDatasetManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_count"
  ],
  "properties": {
    "dataset_version": { "type": "string" },
    "record_count": { "type": "integer", "minimum": 1 },
    "trajectory_modes": {
      "type": "array",
      "items": { "type": "string", "enum": ["pz_only", "pz_cr"] }
    },
    "sample_count_per_mode": { "type": "integer", "minimum": 1 },
    "canonical_dataset_path": { "type": "string" },
    "canonical_dataset_sha256": { "type": "string" },
    "ordering": { "type": "string" },
    "boundary": { "type": "string" },
    "config_hash": { "type": "string" },
    "recipe_name": { "type": "string" },
    "swift_dataset_path": { "type": "string" },
    "swift_dataset_sha256": { "type": "string" },
    "length_audit_path": { "type": "string" },
    "length_audit_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_count",
        "p50",
        "p90",
        "p95",
        "p99",
        "max",
        "count_above_4096",
        "count_above_8192"
      ],
      "properties": {
        "record_count": { "type": "integer", "minimum": 1 },
        "p50": { "type": "integer", "minimum": 0 },
        "p90": { "type": "integer", "minimum": 0 },
        "p95": { "type": "integer", "minimum": 0 },
        "p99": { "type": "integer", "minimum": 0 },
        "max": { "type": "integer", "minimum": 0 },
        "count_above_4096": { "type": "integer", "minimum": 0 },
        "count_above_8192": { "type": "integer", "minimum": 0 }
      }
    },
    "length_audit_proxy_path": { "type": "string" },
    "length_audit_proxy_summary": { "type": "object" },
    "length_audit_true_path": { "type": "string" },
    "length_audit_true_summary": { "type": "object" },
    "resolved_remote_surfaces_path": { "type": "string" },
    "filtered_exports": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "threshold",
          "dataset_path",
          "manifest_path",
          "kept_count",
          "dropped_count",
          "dropped_ratio",
          "true_multimodal_encode",
          "length_audit_backend",
          "threshold_clean_basis",
          "true_threshold_clean_certified"
        ],
        "properties": {
          "threshold": { "type": "integer", "enum": [4096, 8192] },
          "dataset_path": { "type": "string" },
          "manifest_path": { "type": "string" },
          "kept_count": { "type": "integer", "minimum": 0 },
          "dropped_count": { "type": "integer", "minimum": 0 },
          "dropped_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
          "true_multimodal_encode": { "type": "boolean" },
          "length_audit_backend": { "type": "string", "minLength": 1 },
          "threshold_clean_basis": { "type": "string", "minLength": 1 },
          "true_threshold_clean_certified": { "type": "boolean" }
        }
      }
    },
    "filtered_export_summary_by_threshold": {
      "type": "object",
      "additionalProperties": false,
      "required": ["4096", "8192"],
      "properties": {
        "4096": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "threshold",
            "dataset_path",
            "manifest_path",
            "kept_count",
            "dropped_count",
            "dropped_ratio",
            "true_multimodal_encode",
            "length_audit_backend",
            "threshold_clean_basis",
            "true_threshold_clean_certified"
          ],
          "properties": {
            "threshold": { "type": "integer", "const": 4096 },
            "dataset_path": { "type": "string" },
            "manifest_path": { "type": "string" },
            "kept_count": { "type": "integer", "minimum": 0 },
            "dropped_count": { "type": "integer", "minimum": 0 },
            "dropped_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
            "true_multimodal_encode": { "type": "boolean" },
            "length_audit_backend": { "type": "string", "minLength": 1 },
            "threshold_clean_basis": { "type": "string", "minLength": 1 },
            "true_threshold_clean_certified": { "type": "boolean" }
          }
        },
        "8192": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "threshold",
            "dataset_path",
            "manifest_path",
            "kept_count",
            "dropped_count",
            "dropped_ratio",
            "true_multimodal_encode",
            "length_audit_backend",
            "threshold_clean_basis",
            "true_threshold_clean_certified"
          ],
          "properties": {
            "threshold": { "type": "integer", "const": 8192 },
            "dataset_path": { "type": "string" },
            "manifest_path": { "type": "string" },
            "kept_count": { "type": "integer", "minimum": 0 },
            "dropped_count": { "type": "integer", "minimum": 0 },
            "dropped_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
            "true_multimodal_encode": { "type": "boolean" },
            "length_audit_backend": { "type": "string", "minLength": 1 },
            "threshold_clean_basis": { "type": "string", "minLength": 1 },
            "true_threshold_clean_certified": { "type": "boolean" }
          }
        }
      }
    },
    "runtime_probe": { "type": "object" },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
