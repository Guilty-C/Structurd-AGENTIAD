{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentiad.local/tool_run_definition.schema.json",
  "title": "AgentIADToolRunDefinition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "mode",
    "prompt_version",
    "parser_version",
    "execution_boundary",
    "sample_source",
    "backend",
    "seeds",
    "max_tool_turns",
    "artifacts",
    "compare_to",
    "remote_expectations"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "mode": {
      "type": "string",
      "enum": ["pz_only", "pz_cr"]
    },
    "prompt_version": { "type": "string", "minLength": 1 },
    "parser_version": { "type": "string", "minLength": 1 },
    "execution_boundary": {
      "type": "string",
      "enum": ["local", "remote"]
    },
    "sample_source": {
      "$ref": "baseline_run_definition.schema.json#/properties/sample_source"
    },
    "backend": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "name", "policy", "runtime_owner"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["mock", "vllm"]
        },
        "name": { "type": "string", "minLength": 1 },
        "policy": { "type": "string", "minLength": 1 },
        "runtime_owner": { "type": "string", "minLength": 1 }
      }
    },
    "seeds": {
      "type": "array",
      "items": { "type": "integer" },
      "minItems": 1,
      "uniqueItems": true
    },
    "max_tool_turns": {
      "type": "integer",
      "minimum": 1
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root", "raw_outputs", "traces", "predictions", "metrics", "delta"],
      "properties": {
        "root": { "type": "string", "minLength": 1 },
        "raw_outputs": { "type": "string", "minLength": 1 },
        "traces": { "type": "string", "minLength": 1 },
        "predictions": { "type": "string", "minLength": 1 },
        "metrics": { "type": "string", "minLength": 1 },
        "delta": { "type": "string", "minLength": 1 }
      }
    },
    "compare_to": {
      "type": "object",
      "additionalProperties": false,
      "required": ["config_path", "artifact_root"],
      "properties": {
        "config_path": { "type": "string", "minLength": 1 },
        "artifact_root": { "type": "string", "minLength": 1 }
      }
    },
    "remote_expectations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
