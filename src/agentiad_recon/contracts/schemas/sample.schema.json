{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentiad.local/sample.schema.json",
  "title": "AgentIADSample",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sample_id",
    "split",
    "source",
    "category",
    "anomaly_present",
    "anomaly_candidates",
    "image",
    "mask",
    "roi_source",
    "single_agent",
    "allowed_tools",
    "ground_truth",
    "metadata"
  ],
  "properties": {
    "sample_id": {
      "type": "string",
      "minLength": 1
    },
    "split": {
      "type": "string",
      "enum": ["train", "val", "test"]
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "anomaly_present": {
      "type": "boolean"
    },
    "anomaly_candidates": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["uri", "relative_path"],
      "properties": {
        "uri": { "type": "string", "minLength": 1 },
        "relative_path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string" },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 }
      }
    },
    "mask": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["uri", "relative_path"],
      "properties": {
        "uri": { "type": "string", "minLength": 1 },
        "relative_path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string" }
      }
    },
    "roi_source": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["kind", "description"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["mask", "none"]
        },
        "description": { "type": "string", "minLength": 1 },
        "uri": { "type": "string" },
        "relative_path": { "type": "string" }
      }
    },
    "single_agent": {
      "type": "boolean",
      "const": true
    },
    "allowed_tools": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["PZ", "CR"]
      },
      "uniqueItems": true,
      "minItems": 1
    },
    "ground_truth": {
      "$ref": "final_answer.schema.json"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
