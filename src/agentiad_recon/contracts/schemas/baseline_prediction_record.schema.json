{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentiad.local/baseline_prediction_record.schema.json",
  "title": "AgentIADBaselinePredictionRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_id",
    "run_id",
    "sample_id",
    "split",
    "category",
    "seed",
    "tool_mode",
    "tool_usage",
    "prompt_version",
    "parser_version",
    "backend_name",
    "parser_valid",
    "schema_valid",
    "prediction",
    "ground_truth",
    "error_message",
    "failure_reason",
    "raw_output_path",
    "raw_output_sha256",
    "trace_path",
    "first_turn_protocol_gate_mode",
    "first_turn_gate_triggered",
    "first_turn_gate_retry_count",
    "first_turn_gate_recovered",
    "first_turn_gate_outcome",
    "first_turn_gate_repair_attempted",
    "first_turn_gate_repair_succeeded",
    "first_turn_gate_repair_outcome",
    "first_turn_gate_repair_categories",
    "first_turn_gate_repair_original_failure_family",
    "first_turn_gate_repair_failure_family",
    "first_turn_gate_sidecar_path",
    "first_successful_tool_name",
    "first_successful_tool_turn_index",
    "post_pz_transition_audited",
    "post_pz_transition_sidecar_path",
    "post_pz_transition_contract_valid_for_cr",
    "post_pz_transition_mismatch_reasons",
    "post_pz_transition_sanitation_applied",
    "post_pz_transition_sanitation_reason",
    "post_pz_transition_removed_message_count",
    "post_pz_transition_removed_obsolete_terminal_answer_count",
    "post_pz_transition_removed_pz_only_leakage_message_count",
    "post_pz_transition_pre_sanitation_pz_only_leakage_present",
    "post_pz_transition_post_sanitation_pz_only_leakage_present",
    "post_pz_transition_post_sanitation_contract_valid_for_cr",
    "post_pz_transition_post_sanitation_mismatch_reasons",
    "post_pz_second_turn_protocol_event_type",
    "post_pz_second_turn_direct_final_without_cr",
    "post_pz_second_turn_called_cr",
    "post_pz_second_turn_called_non_cr_tool",
    "post_pz_second_turn_parser_valid",
    "post_pz_second_turn_schema_valid",
    "post_pz_second_turn_failure_reason",
    "first_protocol_event_type",
    "first_assistant_output_terminal",
    "tool_call_count",
    "called_tools",
    "terminal_without_tool_call",
    "terminal_false_null_without_tool_call",
    "terminal_answer_turn_index",
    "metadata"
  ],
  "properties": {
    "record_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "sample_id": { "type": "string", "minLength": 1 },
    "split": {
      "type": "string",
      "enum": ["train", "val", "test"]
    },
    "category": { "type": "string", "minLength": 1 },
    "seed": { "type": "integer" },
    "tool_mode": {
      "type": "string",
      "enum": ["no_tools", "pz_only", "pz_cr"]
    },
    "tool_usage": {
      "$ref": "#/$defs/toolUsage"
    },
    "prompt_version": { "type": "string", "minLength": 1 },
    "parser_version": { "type": "string", "minLength": 1 },
    "backend_name": { "type": "string", "minLength": 1 },
    "parser_valid": { "type": "boolean" },
    "schema_valid": { "type": "boolean" },
    "prediction": {
      "anyOf": [
        { "$ref": "final_answer.schema.json" },
        { "type": "null" }
      ]
    },
    "ground_truth": {
      "$ref": "final_answer.schema.json"
    },
    "error_message": {
      "type": ["string", "null"]
    },
    "failure_reason": {
      "type": ["string", "null"]
    },
    "raw_output_path": { "type": "string", "minLength": 1 },
    "raw_output_sha256": { "type": "string", "minLength": 1 },
    "trace_path": { "type": "string", "minLength": 1 },
    "first_turn_protocol_gate_mode": {
      "type": "string",
      "enum": ["off", "retry_once_pz_cr"]
    },
    "first_turn_gate_triggered": { "type": "boolean" },
    "first_turn_gate_retry_count": { "type": "integer", "minimum": 0, "maximum": 1 },
    "first_turn_gate_recovered": { "type": "boolean" },
    "first_turn_gate_outcome": {
      "type": "string",
      "enum": [
        "not_triggered",
        "recovered_to_tool_call",
        "still_terminal_after_retry",
        "retry_parse_failure"
      ]
    },
    "first_turn_gate_repair_attempted": { "type": "boolean" },
    "first_turn_gate_repair_succeeded": { "type": "boolean" },
    "first_turn_gate_repair_outcome": {
      "type": "string",
      "enum": ["not_attempted", "repaired_to_tool_call", "repair_failed"]
    },
    "first_turn_gate_repair_categories": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "wrapper_recovery",
          "quote_normalization",
          "duplicate_candidate_deduplication",
          "alias_canonicalization",
          "bbox_canonicalization"
        ]
      }
    },
    "first_turn_gate_repair_original_failure_family": {
      "type": ["string", "null"]
    },
    "first_turn_gate_repair_failure_family": {
      "type": ["string", "null"],
      "enum": [
        null,
        "retry_repair_unrecoverable_pseudo_observation_payload",
        "retry_repair_ambiguous_multiple_candidates",
        "retry_repair_bbox_not_losslessly_recoverable",
        "retry_repair_unsupported_payload_shape",
        "retry_repair_no_unique_candidate"
      ]
    },
    "first_turn_gate_sidecar_path": {
      "type": ["string", "null"]
    },
    "first_successful_tool_name": {
      "type": ["string", "null"],
      "enum": [null, "PZ", "CR"]
    },
    "first_successful_tool_turn_index": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "post_pz_transition_audited": { "type": "boolean" },
    "post_pz_transition_sidecar_path": {
      "type": ["string", "null"]
    },
    "post_pz_transition_contract_valid_for_cr": {
      "type": ["boolean", "null"]
    },
    "post_pz_transition_mismatch_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "post_pz_transition_missing_reinserted_pz_result",
          "post_pz_transition_missing_cr_tool",
          "post_pz_transition_missing_query_image_instruction",
          "post_pz_transition_pz_only_leakage",
          "post_pz_transition_missing_tool_context"
        ]
      }
    },
    "post_pz_transition_sanitation_applied": { "type": "boolean" },
    "post_pz_transition_sanitation_reason": { "type": "string", "minLength": 1 },
    "post_pz_transition_removed_message_count": {
      "type": "integer",
      "minimum": 0
    },
    "post_pz_transition_removed_obsolete_terminal_answer_count": {
      "type": "integer",
      "minimum": 0
    },
    "post_pz_transition_removed_pz_only_leakage_message_count": {
      "type": "integer",
      "minimum": 0
    },
    "post_pz_transition_pre_sanitation_pz_only_leakage_present": {
      "type": "boolean"
    },
    "post_pz_transition_post_sanitation_pz_only_leakage_present": {
      "type": "boolean"
    },
    "post_pz_transition_post_sanitation_contract_valid_for_cr": {
      "type": ["boolean", "null"]
    },
    "post_pz_transition_post_sanitation_mismatch_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "post_pz_transition_missing_reinserted_pz_result",
          "post_pz_transition_missing_cr_tool",
          "post_pz_transition_missing_query_image_instruction",
          "post_pz_transition_pz_only_leakage",
          "post_pz_transition_missing_tool_context"
        ]
      }
    },
    "post_pz_second_turn_protocol_event_type": {
      "type": ["string", "null"],
      "enum": [null, "tool_call", "final_answer", "parse_failure"]
    },
    "post_pz_second_turn_direct_final_without_cr": { "type": "boolean" },
    "post_pz_second_turn_called_cr": { "type": "boolean" },
    "post_pz_second_turn_called_non_cr_tool": { "type": "boolean" },
    "post_pz_second_turn_parser_valid": {
      "type": ["boolean", "null"]
    },
    "post_pz_second_turn_schema_valid": {
      "type": ["boolean", "null"]
    },
    "post_pz_second_turn_failure_reason": {
      "type": ["string", "null"]
    },
    "first_protocol_event_type": {
      "type": "string",
      "enum": ["final_answer", "tool_call", "parse_failure", "runtime_fail_before_generation", "unknown"]
    },
    "first_assistant_output_terminal": { "type": "boolean" },
    "tool_call_count": { "type": "integer", "minimum": 0 },
    "called_tools": {
      "type": "array",
      "items": { "type": "string", "enum": ["PZ", "CR"] }
    },
    "terminal_without_tool_call": { "type": "boolean" },
    "terminal_false_null_without_tool_call": { "type": "boolean" },
    "terminal_answer_turn_index": { "type": ["integer", "null"], "minimum": 0 },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "toolUsage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total_calls", "samples_with_tool_call", "per_tool_counts"],
      "properties": {
        "total_calls": {
          "type": "integer",
          "minimum": 0
        },
        "samples_with_tool_call": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1
        },
        "per_tool_counts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["PZ", "CR"],
          "properties": {
            "PZ": { "type": "integer", "minimum": 0 },
            "CR": { "type": "integer", "minimum": 0 }
          }
        }
      }
    }
  }
}
