{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentiad.local/baseline_prediction_record.schema.json",
  "title": "AgentIADBaselinePredictionRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_id",
    "run_id",
    "sample_id",
    "split",
    "category",
    "seed",
    "tool_mode",
    "tool_usage",
    "prompt_version",
    "parser_version",
    "backend_name",
    "parser_valid",
    "schema_valid",
    "prediction",
    "ground_truth",
    "error_message",
    "failure_reason",
    "raw_output_path",
    "raw_output_sha256",
    "trace_path",
    "metadata"
  ],
  "properties": {
    "record_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "sample_id": { "type": "string", "minLength": 1 },
    "split": {
      "type": "string",
      "enum": ["train", "val", "test"]
    },
    "category": { "type": "string", "minLength": 1 },
    "seed": { "type": "integer" },
    "tool_mode": {
      "type": "string",
      "enum": ["no_tools", "pz_only", "pz_cr"]
    },
    "tool_usage": {
      "$ref": "#/$defs/toolUsage"
    },
    "prompt_version": { "type": "string", "minLength": 1 },
    "parser_version": { "type": "string", "minLength": 1 },
    "backend_name": { "type": "string", "minLength": 1 },
    "parser_valid": { "type": "boolean" },
    "schema_valid": { "type": "boolean" },
    "prediction": {
      "anyOf": [
        { "$ref": "final_answer.schema.json" },
        { "type": "null" }
      ]
    },
    "ground_truth": {
      "$ref": "final_answer.schema.json"
    },
    "error_message": {
      "type": ["string", "null"]
    },
    "failure_reason": {
      "type": ["string", "null"]
    },
    "raw_output_path": { "type": "string", "minLength": 1 },
    "raw_output_sha256": { "type": "string", "minLength": 1 },
    "trace_path": { "type": "string", "minLength": 1 },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "toolUsage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total_calls", "samples_with_tool_call", "per_tool_counts"],
      "properties": {
        "total_calls": {
          "type": "integer",
          "minimum": 0
        },
        "samples_with_tool_call": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1
        },
        "per_tool_counts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["PZ", "CR"],
          "properties": {
            "PZ": { "type": "integer", "minimum": 0 },
            "CR": { "type": "integer", "minimum": 0 }
          }
        }
      }
    }
  }
}
